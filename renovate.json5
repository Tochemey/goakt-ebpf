{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended", ":semanticCommitTypeAll(chore)"],
  assigneesFromCodeOwners: true,
  dependencyDashboard: false,
  rebaseWhen: "conflicted",
  schedule: "on Wednesdays",
  prHourlyLimit: 5,
  minimumReleaseAge: "14 days",
  rangeStrategy: "widen",
  constraints: {
    go: "1.26",
  },
  enabledManagers: ["custom.regex", "dockerfile", "github-actions", "gomod"],
  postUpdateOptions: ["gomodUpdateImportPaths", "gomodTidy"],
  ignoreDeps: [
    "k8s.io/api",
    "k8s.io/apimachinery",
    "k8s.io/client-go",
    "k8s.io/kube-openapi",
    "sigs.k8s.io/json",
    "sigs.k8s.io/structured-merge-diff/v4",
    "sigs.k8s.io/structured-merge-diff/v6",
    "k8s.io/utils",
  ],
  packageRules: [
    {
      groupName: "go minor and patch",
      matchCategories: ["golang"],
      matchUpdateTypes: ["digest", "patch", "minor"],
      minimumReleaseAge: "3 days",
    },
  ],
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["renovate.json5$/"],
      matchStrings: [
        'constraints: {(\\s*\\n\\s*)"go":\\s*"(?<currentValue>.*?)"',
      ],
      depNameTemplate: "go",
      datasourceTemplate: "golang-version",
      versioningTemplate: "npm",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/Earthfile$/"],
      matchStrings: ["FROM golang:(?<currentValue>[^\\s\\n]+)"],
      depNameTemplate: "golang",
      datasourceTemplate: "docker",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/Earthfile$/"],
      matchStrings: [
        "github.com/cilium/ebpf/cmd/bpf2go@(?<currentValue>v[\\d.]+)",
      ],
      depNameTemplate: "github.com/cilium/ebpf",
      datasourceTemplate: "go",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/Dockerfile$/"],
      matchStrings: [
        "github.com/cilium/ebpf/cmd/bpf2go@(?<currentValue>v[\\d.]+)",
      ],
      depNameTemplate: "github.com/cilium/ebpf",
      datasourceTemplate: "go",
    },
  ],
}
